message: "If you use fsvlm in research or product work, please cite it using the metadata below."
type: software
title: "fsvlm: Few-shot Fine-tuning Benchmarker for Vision-Language Models"
version: 0.1.0
date-released: 2026-04-21
url: "https://github.com/ahmadhasan2k8/fsvlm"
repository-code: "https://github.com/ahmadhasan2k8/fsvlm"
license: Apache-2.0
authors:
  - family-names: "Hasan"
    given-names: "Ahmad Jarjis"
keywords:
  - "defect detection"
  - "visual inspection"
  - "vision-language models"
  - "Gemma 4"
  - "LoRA"
  - "QLoRA"
  - "few-shot learning"
