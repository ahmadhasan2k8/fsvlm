      "assertions": [
        {"name": "did_not_trigger_setup", "type": "trigger_negation", "value": "setup"},
        {"name": "skill_triggered", "type": "trigger", "value": "inspect"}
      ]
    },
    {
      "eval_id": 4,
      "eval_name": "model-not-found-error-recovery",
      "prompt": "I'm getting a 'model not found' error when I try to inspect. Help.",
      "expected_skill": "setup",
      "assertions": [
        {"name": "skill_triggered", "type": "trigger", "value": "setup"},
        {"name": "produced_eval_artifact", "type": "file_exists", "value": "~/.fsvlm/setup_status.json"}
